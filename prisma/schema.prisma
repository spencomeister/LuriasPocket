// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── GBF Data Models ──────────────────────────────────────────────────────────

model Character {
  id          Int      @id @default(autoincrement())
  gameId      String   @unique
  name        String
  nameJp      String?
  rarity      String   @default("SSR")
  element     String
  weapon      String
  category    String?
  series      String?
  imageUrl    String?
  releaseDate String?
  obtain      String?
  skills      String?  // JSON: string[]
  abilities   String?  // JSON: string[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([element, rarity])
  @@index([category])
  @@index([series])
  @@index([releaseDate])
}

model Summon {
  id        Int      @id @default(autoincrement())
  gameId    String   @unique
  name      String
  nameJp    String?
  rarity    String?
  element   String
  category  String?
  imageUrl  String?
  mainAura  String?
  subAura   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([element, category, rarity])
  @@index([name])
}

model Weapon {
  id         Int      @id @default(autoincrement())
  gameId     String   @unique
  name       String
  nameJp     String?
  rarity     String?
  element    String
  weaponType String
  category   String?
  imageUrl   String?
  skills     String?  // JSON: string[]
  obtain     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([element, weaponType, category, rarity])
  @@index([name])
}

// ── Auth Models ───────────────────────────────────────────────────────────────

model User {
  id            String          @id @default(cuid())
  loginId       String          @unique
  name          String
  password      String
  inventory     UserInventory[]
  shareTokens   ShareToken[]
  createdAt     DateTime        @default(now())
}

// ── Admin Config ──────────────────────────────────────────────────────────────

model AdminConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

// ── Share Token (一時URL共有) ─────────────────────────────────────────────────

model ShareToken {
  id        Int      @id @default(autoincrement())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Translation (日本語名マッピング) ──────────────────────────────────────────

model Translation {
  id       Int    @id @default(autoincrement())
  category String // "weaponType" / "series" / "characterType" / "obtain"
  key      String // 英語値
  valueJp  String // 日本語訳

  @@unique([category, key])
}

// ── System Exclusion (システム全体の除外設定) ──────────────────────────────────

model SystemExclusion {
  id    Int    @id @default(autoincrement())
  type  String // "category" / "weaponType" / "series"
  value String // 除外する値

  @@unique([type, value])
}

// ── Inventory / Usage Tracker ─────────────────────────────────────────────────

model UserInventory {
  id          Int      @id @default(autoincrement())
  userId      String
  itemType    String   // "character" | "summon" | "weapon"
  itemId      Int
  quantity    Int      @default(1)
  level       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
}
