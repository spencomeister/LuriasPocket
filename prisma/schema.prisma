// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── GBF Data Models ──────────────────────────────────────────────────────────

model Character {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  nameJp      String?
  rarity      String   @default("SSR")
  element     String
  weapon      String
  category    String?
  imageUrl    String?
  releaseDate String?
  obtain      String?
  skills      String?  // JSON: string[]
  abilities   String?  // JSON: string[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Summon {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  nameJp    String?
  element   String
  category  String?
  imageUrl  String?
  mainAura  String?
  subAura   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Weapon {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  nameJp     String?
  element    String
  weaponType String
  category   String?
  imageUrl   String?
  skills     String?  // JSON: string[]
  obtain     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Auth Models (NextAuth.js v5) ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  inventory     UserInventory[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Inventory / Usage Tracker ─────────────────────────────────────────────────

model UserInventory {
  id          Int      @id @default(autoincrement())
  userId      String
  itemType    String   // "character" | "summon" | "weapon"
  itemId      Int
  quantity    Int      @default(1)
  uncap       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
}
