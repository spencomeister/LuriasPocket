# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# NextAuth.js secret (generate with: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-strong-random-secret-32-chars"

# Optional: OAuth provider credentials
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# Admin initial password (change on first login)
ADMIN_INITIAL_PASSWORD="change-me-on-first-login"

# App URL for share links
NEXT_PUBLIC_APP_URL="http://localhost:3000"
