# ── Turso (libSQL) Database ──────────────────────────
# ローカル開発: file:./prisma/dev.db
# 本番 (Turso): libsql://your-db-name-your-org.turso.io
TURSO_DATABASE_URL="file:./prisma/dev.db"
TURSO_AUTH_TOKEN=""

# Prisma CLI 用 (マイグレーション)
DATABASE_URL="file:./prisma/dev.db"

# NextAuth.js secret (generate with: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-strong-random-secret-32-chars"

# Admin initial password (change on first login)
ADMIN_INITIAL_PASSWORD="change-me-on-first-login"

# App URL for share links (本番では Vercel のドメインまたはカスタムドメイン)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
